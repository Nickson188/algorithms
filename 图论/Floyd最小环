const int N=110;
int n,m,a,b,c,ans=1e8;
int w[N][N],d[N][N];

void Floyd(){
  for(int k=1; k<=n; k++){
    for(int i=1; i<k; i++)
    for(int j=i+1; j<k; j++)
      ans=min(ans,d[i][j]+w[j][k]+w[k][i]); //更新最小环
      
    for(int i=1; i<=n; i++)
    for(int j=1; j<=n; j++)
      d[i][j]=min(d[i][j],d[i][k]+d[k][j]); //更新最短路
  }  
}
